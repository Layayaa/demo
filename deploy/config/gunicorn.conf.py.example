# Gunicorn 配置文件
# 文件位置: /opt/inquiry-system/config/gunicorn.conf.py

import multiprocessing
import os

# 绑定地址
bind = "127.0.0.1:5000"

# 工作进程数（推荐：CPU核心数 * 2 + 1）
workers = multiprocessing.cpu_count() * 2 + 1

# 工作模式（gevent 支持高并发）
worker_class = "gevent"

# 每个工作进程的最大并发数
worker_connections = 1000

# 超时时间（秒）
timeout = 120

# Keep-alive 时间
keepalive = 5

# 最大请求数后重启工作进程（防止内存泄漏）
max_requests = 1000
max_requests_jitter = 100

# 日志配置
accesslog = "/opt/inquiry-system/logs/gunicorn/access.log"
errorlog = "/opt/inquiry-system/logs/gunicorn/error.log"
loglevel = "info"

# 进程名
proc_name = "inquiry-system"

# PID 文件
pidfile = "/opt/inquiry-system/logs/gunicorn.pid"

# 预加载应用（共享内存）
preload_app = True

# 守护进程模式
daemon = False
