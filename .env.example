# ============================
# 企业内部历史询价复用系统 - 环境变量配置
# 使用方法: cp .env.example .env  然后修改下面的值
# ============================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root_password_2026
MYSQL_USER=inquiry
MYSQL_PASSWORD=change_me_db_password_2026

# ---------- Flask 应用 ----------
# 必须修改为一个随机字符串，可用命令生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_random_secret_key

# CORS 允许的来源（多个用逗号分隔），不填则仅允许 localhost
# 示例: http://8.219.223.217,http://your-domain.com
CORS_ORIGINS=

# 如果配置了 HTTPS，设为 true
SESSION_COOKIE_SECURE=false

# ---------- 管理员初始账号 ----------
# 首次启动时创建，之后修改此处不影响已有账号
INITIAL_ADMIN_PHONE=13800138000
# 留空则使用手机号后六位作为默认密码
INITIAL_ADMIN_PASSWORD=
